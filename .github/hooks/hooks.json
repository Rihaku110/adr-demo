{
  "version": 1,
  "hooks": {
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "echo '[ADR Reminder] hook fired'",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "bash .github/hooks/level-1-enforced/gate-adr-check.sh dir adrs",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}